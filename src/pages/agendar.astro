---
import BaseLayout from "../layouts/BaseLayout.astro";
import AgendarFlow from "../components/agendar/AgendarFlow";
---

<BaseLayout title="Agendar consulta — SGL">
  <main class="min-h-screen py-14 md:py-20">
    <div class="max-w-3xl mx-auto px-4 md:px-8">

      <a
        href="/"
        class="font-sans text-sm text-sgl-gray-mid hover:text-sgl-gold transition-colors duration-200 inline-flex items-center gap-1.5 mb-10"
      >
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none">
          <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5"
            stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Volver al inicio
      </a>

      <AgendarFlow client:load />

    </div>
  </main>
</BaseLayout>
