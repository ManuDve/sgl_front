---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Servicio {
  id: number;
  nombre: string;
  descripcion: string;
  precio: number;
}

let services: Servicio[] = [];
let fetchError = false;
try {
  const res = await fetch("http://localhost:8080/api/services");
  if (res.ok) {
    const body = await res.json();
    services = body.data ?? [];
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

function formatCLP(n: number): string {
  return new Intl.NumberFormat("es-CL", {
    style: "currency",
    currency: "CLP",
    maximumFractionDigits: 0,
  }).format(n);
}
---

<BaseLayout
  title="SGL | Asesoría legal a tu alcance"
  description="Estudio jurídico en Santiago. Asesoría legal en divorcio, laboral, herencias y más. Agenda tu consulta en línea."
>

  <!-- ─── HERO ────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden py-20 md:py-32">

    <!-- Glow decorativo de fondo -->
    <div class="pointer-events-none absolute inset-0 flex items-start justify-center overflow-hidden" aria-hidden="true">
      <div class="w-[800px] h-[500px] rounded-full opacity-10"
        style="background: radial-gradient(ellipse, var(--color-sgl-gold) 0%, transparent 70%); filter: blur(80px); transform: translateY(-30%);">
      </div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 md:px-8 grid lg:grid-cols-2 gap-12 items-center">

      <!-- Texto -->
      <div>
        <p class="hero-label font-sans text-xs text-sgl-gold uppercase tracking-[0.2em]"
          style="animation: fade-up 0.5s ease both; animation-delay: 0ms;">
          Estudio jurídico · Santiago, Chile
        </p>

        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-sgl-white leading-tight mt-4"
          style="animation: fade-up 0.6s ease both; animation-delay: 100ms;">
          Asesoría legal
          <span class="block" style="background: linear-gradient(90deg, var(--color-sgl-white), var(--color-sgl-gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            clara y humana
          </span>
        </h1>

        <p class="font-sans text-base md:text-lg text-sgl-gray-mid leading-relaxed mt-5 max-w-md"
          style="animation: fade-up 0.6s ease both; animation-delay: 200ms;">
          Te acompañamos en cada paso con orientación profesional, transparente
          y enfocada en resultados concretos.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3"
          style="animation: fade-up 0.6s ease both; animation-delay: 300ms;">
          <a
            href="/agendar"
            class="bg-sgl-gold hover:bg-sgl-gold-light text-sgl-black font-semibold px-7 py-3.5 rounded transition-colors duration-200 text-center"
          >
            Agendar consulta
          </a>
          <a
            href="#servicios"
            class="border border-sgl-gold/50 text-sgl-gold hover:border-sgl-gold hover:bg-sgl-gold/10 font-semibold px-7 py-3.5 rounded transition-colors duration-200 text-center"
          >
            Ver servicios
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3"
          style="animation: fade-up 0.6s ease both; animation-delay: 400ms;">
          {[
            { valor: "+10", label: "años de experiencia" },
            { valor: "+200", label: "casos resueltos" },
            { valor: "100%", label: "compromiso" },
          ].map(({ valor, label }) => (
            <div class="flex flex-col gap-0.5">
              <span class="font-serif text-2xl font-bold text-sgl-gold">{valor}</span>
              <span class="font-sans text-xs text-sgl-gray-mid">{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Card derecha -->
      <div class="hidden lg:block"
        style="animation: fade-right 0.7s ease both; animation-delay: 250ms;">
        <div class="relative rounded-2xl border border-sgl-gold/20 bg-sgl-gray overflow-hidden p-8"
          style="box-shadow: 0 0 80px rgba(201,168,76,0.08);">
          <!-- Línea accent superior -->
          <div class="absolute top-0 left-0 right-0 h-px"
            style="background: linear-gradient(90deg, transparent, var(--color-sgl-gold), transparent);">
          </div>

          <p class="font-sans text-xs text-sgl-gold uppercase tracking-widest">Por qué elegirnos</p>
          <p class="font-serif text-2xl font-semibold text-sgl-white mt-3 leading-snug">
            Tu caso en manos de profesionales comprometidos
          </p>
          <p class="font-sans text-sm text-sgl-gray-mid leading-relaxed mt-3">
            Analizamos tu situación y proponemos acciones concretas para avanzar con seguridad y claridad.
          </p>

          <ul class="mt-6 flex flex-col gap-3">
            {[
              "Consulta inicial sin compromiso",
              "Comunicación directa con tu abogado",
              "Plazos claros y tarifas transparentes",
              "Seguimiento continuo de tu caso",
            ].map((item) => (
              <li class="flex items-center gap-3 font-sans text-sm text-sgl-white">
                <span class="shrink-0 w-5 h-5 rounded-full bg-sgl-gold/15 flex items-center justify-center">
                  <svg class="w-3 h-3 text-sgl-gold" viewBox="0 0 12 12" fill="none">
                    <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── SERVICIOS ────────────────────────────────────────────── -->
  <section id="servicios" class="py-20 md:py-28 border-t border-sgl-gold/10">
    <div class="max-w-6xl mx-auto px-4 md:px-8">

      <div class="max-w-xl" data-animate>
        <p class="font-sans text-xs text-sgl-gold uppercase tracking-widest">Áreas de práctica</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-sgl-white mt-3">
          Servicios legales especializados
        </h2>
        <p class="font-sans text-base text-sgl-gray-mid leading-relaxed mt-3">
          Cobertura integral en las materias legales más demandadas, con enfoque en soluciones prácticas.
        </p>
      </div>

      {fetchError || services.length === 0 ? (
        <p class="mt-12 font-sans text-base text-sgl-gray-mid">
          Los servicios no están disponibles en este momento.
        </p>
      ) : (
        <div class="mt-12 grid gap-5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 items-start">
          {services.map((svc, i) => (
            <details
              class="svc-card group bg-sgl-gray rounded-xl border border-sgl-gray-light/10
                hover:border-sgl-gold/40 transition-colors duration-200"
              data-animate
              style={`transition-delay: ${i * 60}ms`}
            >
              <summary class="flex items-center justify-between gap-3 px-6 py-5 cursor-pointer select-none">
                <div class="flex-1 min-w-0">
                  <h3 class="font-serif text-lg font-semibold text-sgl-white leading-snug">{svc.nombre}</h3>
                  <p class="font-sans text-sm text-sgl-gold mt-1">{formatCLP(svc.precio)}</p>
                </div>
                <svg
                  class="svc-chevron shrink-0 w-5 h-5 text-sgl-gray-mid"
                  viewBox="0 0 20 20" fill="none"
                  aria-hidden="true"
                >
                  <path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </summary>

              <div class="svc-body">
                <div>
                  <div class="px-6 pb-6 pt-1 flex flex-col gap-4 border-t border-sgl-gold/10">
                    <p class="font-sans text-sm text-sgl-gray-mid leading-relaxed">{svc.descripcion}</p>
                    <a
                      href="/agendar"
                      class="self-start bg-sgl-gold hover:bg-sgl-gold-light text-sgl-black font-semibold px-6 py-3 rounded transition-colors duration-200 text-sm"
                    >
                      Agendar consulta
                    </a>
                  </div>
                </div>
              </div>
            </details>
          ))}
        </div>
      )}
    </div>
  </section>


  <!-- ─── VALORES ──────────────────────────────────────────────── -->
  <section id="valores" class="py-20 md:py-28 border-t border-sgl-gold/10">
    <div class="max-w-6xl mx-auto px-4 md:px-8">

      <div class="text-center max-w-2xl mx-auto" data-animate>
        <p class="font-sans text-xs text-sgl-gold uppercase tracking-widest">Nuestro compromiso</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-sgl-white mt-3">
          Por qué confiar en nosotros
        </h2>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {[
          {
            num: "01",
            titulo: "Experiencia probada",
            desc: "Más de una década resolviendo casos en civil, laboral y familia con enfoque estratégico.",
          },
          {
            num: "02",
            titulo: "Comunicación transparente",
            desc: "Información clara, pasos definidos y acceso directo a tu abogado en todo momento.",
          },
          {
            num: "03",
            titulo: "Resultados concretos",
            desc: "Acciones eficientes y orientadas a proteger tus derechos y optimizar tu tiempo.",
          },
        ].map(({ num, titulo, desc }, i) => (
          <div
            class="relative border border-sgl-gray-light/10 rounded-xl p-7 bg-sgl-gray
              hover:border-sgl-gold/30 transition-colors duration-300"
            data-animate
            style={`transition-delay: ${i * 100}ms`}
          >
            <span class="font-serif text-5xl font-bold text-sgl-gold/10 absolute top-5 right-6 select-none">{num}</span>
            <h3 class="font-serif text-xl font-semibold text-sgl-white relative">{titulo}</h3>
            <p class="font-sans text-sm text-sgl-gray-mid leading-relaxed mt-3 relative">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── CONTACTO ─────────────────────────────────────────────── -->
  <section id="contacto" class="py-20 md:py-28 border-t border-sgl-gold/10">
    <div class="max-w-6xl mx-auto px-4 md:px-8">

      <div class="text-center max-w-2xl mx-auto" data-animate>
        <p class="font-sans text-xs text-sgl-gold uppercase tracking-widest">Atención directa</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-sgl-white mt-3">
          Estamos para ayudarte
        </h2>
      </div>

      <div class="mt-12 grid gap-5 grid-cols-1 md:grid-cols-2" data-animate style="transition-delay:100ms">

        <!-- Teléfono -->
        <a
          href="tel:+56223456789"
          class="flex items-start gap-4 bg-sgl-gray rounded-xl border border-sgl-gray-light/10 p-6
            hover:border-sgl-gold/40 transition-colors duration-200 group"
        >
          <div class="w-10 h-10 rounded-lg bg-sgl-gold/10 text-sgl-gold flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12 19.79 19.79 0 0 1 1.08 3.4 2 2 0 0 1 3.05 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.17a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="font-sans text-xs text-sgl-gold uppercase tracking-widest mb-1">Teléfono</p>
            <p class="font-serif text-lg font-semibold text-sgl-white group-hover:text-sgl-gold-light transition-colors duration-200">
              +56 2 2345 6789
            </p>
          </div>
        </a>

        <!-- Email -->
        <a
          href="mailto:contacto@sglabogados.cl"
          class="flex items-start gap-4 bg-sgl-gray rounded-xl border border-sgl-gray-light/10 p-6
            hover:border-sgl-gold/40 transition-colors duration-200 group"
        >
          <div class="w-10 h-10 rounded-lg bg-sgl-gold/10 text-sgl-gold flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="font-sans text-xs text-sgl-gold uppercase tracking-widest mb-1">Email</p>
            <p class="font-serif text-lg font-semibold text-sgl-white group-hover:text-sgl-gold-light transition-colors duration-200">
              contacto@sglabogados.cl
            </p>
          </div>
        </a>

        <!-- Dirección -->
        <div class="flex items-start gap-4 bg-sgl-gray rounded-xl border border-sgl-gray-light/10 p-6 md:col-span-2">
          <div class="w-10 h-10 rounded-lg bg-sgl-gold/10 text-sgl-gold flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <p class="font-sans text-xs text-sgl-gold uppercase tracking-widest mb-1">Dirección</p>
            <p class="font-serif text-lg font-semibold text-sgl-white">
              Av. Providencia 1234, Of. 502
            </p>
            <p class="font-sans text-sm text-sgl-gray-mid mt-0.5">Providencia, Santiago</p>
          </div>
        </div>
      </div>

      <!-- Botón WhatsApp -->
      <div class="mt-8 flex justify-center" data-animate style="transition-delay:200ms">
        <a
          href="https://wa.me/56912345678"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 font-semibold font-sans px-8 py-4 rounded-lg transition-colors duration-200 text-sgl-white text-base"
          style="background-color: #25D366;"
          onmouseover="this.style.backgroundColor='#20b057'"
          onmouseout="this.style.backgroundColor='#25D366'"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
          </svg>
          Escríbenos por WhatsApp
        </a>
      </div>
    </div>
  </section>


  <!-- ─── CTA FINAL ────────────────────────────────────────────── -->
  <section class="py-20 md:py-28 border-t border-sgl-gold/10">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <div
        class="relative rounded-2xl overflow-hidden p-10 md:p-16 flex flex-col md:flex-row md:items-center md:justify-between gap-8"
        data-animate
        style="background: linear-gradient(135deg, #1A1A1A 0%, #0f0f0f 100%); box-shadow: 0 0 0 1px rgba(201,168,76,0.25), 0 0 60px rgba(201,168,76,0.05);"
      >
        <!-- Glow interior -->
        <div class="pointer-events-none absolute bottom-0 right-0 w-96 h-64 rounded-full opacity-20"
          style="background: radial-gradient(ellipse, var(--color-sgl-gold) 0%, transparent 70%); filter: blur(60px);" aria-hidden="true">
        </div>

        <div class="relative max-w-lg">
          <p class="font-sans text-xs text-sgl-gold uppercase tracking-widest">Da el primer paso</p>
          <p class="font-serif text-3xl md:text-4xl font-semibold text-sgl-white mt-3 leading-snug">
            Agenda tu consulta hoy
          </p>
          <p class="font-sans text-base text-sgl-gray-mid leading-relaxed mt-3">
            Cuéntanos tu caso y recibe orientación profesional de un equipo cercano y comprometido.
          </p>
        </div>

        <a
          href="/agendar"
          class="relative shrink-0 bg-sgl-gold hover:bg-sgl-gold-light text-sgl-black font-semibold px-8 py-4 rounded-lg transition-colors duration-200 text-center text-base"
        >
          Comenzar ahora
        </a>
      </div>
    </div>
  </section>


  <!-- ─── FOOTER ───────────────────────────────────────────────── -->
  <footer class="bg-sgl-gray border-t border-sgl-gold/20 py-8">
    <div class="max-w-6xl mx-auto px-4 md:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <span class="font-serif text-lg text-sgl-white">
        SGL<span class="text-sgl-gold">.</span>
      </span>
      <p class="font-sans text-xs text-sgl-gray-mid">
        © {new Date().getFullYear()} SGL Estudio Jurídico · Santiago, Chile
      </p>
      <div class="flex gap-5 font-sans text-xs text-sgl-gray-mid">
        <a href="/terminos"  class="hover:text-sgl-gold transition-colors">Términos y condiciones</a>
        <a href="/privacidad" class="hover:text-sgl-gold transition-colors">Privacidad</a>
      </div>
    </div>
  </footer>

</BaseLayout>

<script>
  // Scroll-reveal con IntersectionObserver
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll("[data-animate]").forEach((el) => observer.observe(el));

  // Animación de cierre para cards de servicio
  document.querySelectorAll("details.svc-card").forEach((det) => {
    det.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest("summary") || !det.hasAttribute("open")) return;
      e.preventDefault();
      const body = det.querySelector(".svc-body") as HTMLElement | null;
      if (!body) return;
      body.style.gridTemplateRows = "0fr";
      setTimeout(() => {
        det.removeAttribute("open");
        body.style.gridTemplateRows = "";
      }, 280);
    });
  });
</script>
