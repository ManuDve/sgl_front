---
import BaseLayout from "./BaseLayout.astro";
import LogoutButton from "../components/admin/LogoutButton";

const { title = "Admin — SGL" } = Astro.props;
const pathname = Astro.url.pathname;

function navClass(href: string) {
  const active = pathname.startsWith(href);
  return `font-sans text-sm transition-colors duration-150 pb-0.5 border-b ${
    active
      ? "text-sgl-white border-sgl-gold"
      : "text-sgl-gray-mid border-transparent hover:text-sgl-white hover:border-sgl-gold/40"
  }`;
}
---

<BaseLayout title={title}>
  <div class="min-h-screen flex flex-col">
    <header class="bg-sgl-black/95 backdrop-blur border-b border-sgl-gold/20 sticky top-0 z-10">
      <nav class="max-w-6xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between gap-6">
        <span class="font-serif text-xl text-sgl-white shrink-0">
          SGL<span class="text-sgl-gold">.</span>
          <span class="font-sans text-sm text-sgl-gray-mid ml-2">Admin</span>
        </span>

        <div class="flex items-center gap-5 md:gap-7">
          <a href="/admin/dashboard" class={navClass("/admin/dashboard")}>Dashboard</a>
          <a href="/admin/calendario" class={navClass("/admin/calendario")}>Calendario</a>
        </div>

        <LogoutButton client:load />
      </nav>
    </header>

    <main class="flex-1 max-w-6xl mx-auto w-full px-4 md:px-8 py-10 md:py-12">
      <slot />
    </main>
  </div>
</BaseLayout>
